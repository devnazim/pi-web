# npm package defense-in-depth.
# The package.json "files" field is the primary publish allowlist; keep this
# denylist aligned so private/local/development artifacts stay out if packaging
# settings change.

# Dependencies
/node_modules/

# Source/dev-only files
/src/
/web/
/scripts/
/tsconfig*.json
/vite.config.*
/postcss.config.*
/tailwind.config.*

# Build artifacts that should not be published
/dist/**/*.map
*.tsbuildinfo
*.tgz

# Local app/runtime state
/.pi-web/
/.pi/

# Environment and local config
.env
.env.*
!.env.example
.envrc
.npmrc

# Secrets / credentials / certificates
*.pem
*.key
*.p12
*.pfx
*.crt
*.cert
*.jks
id_rsa
id_rsa.*
id_ed25519
id_ed25519.*

# Logs
/logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Tooling caches and coverage
/.cache/
/.vite/
/coverage/
/.nyc_output/

# VCS / OS / editor files
/.git/
/.github/
.DS_Store
/.idea/
/.vscode/
*.swp
